{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pseudoai.news/schema/news.schema.json",
  "title": "PseudoAI News Feed",
  "description": "Schema for curated news items used in the PseudoAI Sales website.",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": [
      "slug",
      "title",
      "publishedAt",
      "source",
      "originalUrl",
      "quote",
      "summary",
      "relevanceBullets"
    ],
    "additionalProperties": false,
    "properties": {
      "slug": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$",
        "description": "URL-safe unique identifier (kebab-case)."
      },
      "title": {
        "type": "string",
        "minLength": 10,
        "description": "Full article title."
      },
      "publishedAt": {
        "type": "string",
        "format": "date",
        "description": "Publication date in ISO format (YYYY-MM-DD)."
      },
      "source": {
        "type": "string",
        "minLength": 2,
        "description": "Name of the publication."
      },
      "originalUrl": {
        "type": "string",
        "format": "uri",
        "description": "Canonical URL of the original article."
      },
      "quote": {
        "type": "string",
        "maxLength": 200,
        "description": "Short quote or excerpt (max ~200 characters)."
      },
      "summary": {
        "type": "string",
        "minLength": 50,
        "description": "2–4 sentence neutral summary written in own words."
      },
      "relevanceBullets": {
        "type": "array",
        "minItems": 2,
        "maxItems": 2,
        "items": {
          "type": "string",
          "minLength": 20
        },
        "description": "Exactly two bullets explaining why this article is relevant for pseudoAI."
      },
      "tags": {
        "type": "array",
        "uniqueItems": true,
        "items": {
          "type": "string",
          "enum": [
            "shadow-ai",
            "governance",
            "security",
            "privacy",
            "compliance",
            "data-leakage",
            "byoai",
            "attack-surface",
            "shadow-it"
          ]
        },
        "description": "Optional taxonomy tags."
      }
    }
  }
}
